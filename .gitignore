# ─── Dependencias ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Entorno / Secrets ───
.env
.env.*
!.env.example

# ─── Build / Dist ───
dist/
build/
out/
*.tsbuildinfo

# ─── Testing / Coverage ───
coverage/
.nyc_output/
*.lcov

# ─── Logs ───
logs/
*.log
lerna-debug.log*
.pnpm-debug.log*

# ─── Caché ───
.npm
.eslintcache
.stylelintcache
.prettiercache
.parcel-cache

# ─── Editores / IDEs ───
.vs/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─── Sistema operativo ───
Thumbs.db
Desktop.ini

# ─── Render / Deploy ───
.render/

# ─── Misc ───
*.pid
*.seed
*.pid.lock
.lock-wscript
.node_repl_history